# Zkopíruj na .env a uprav podle potřeby: cp .env.example .env
# Všechny hodnoty mají rozumné výchozí nastavení – .env je volitelný.

# --- Databáze (PostgreSQL) ---
POSTGRES_USER=kucharka
POSTGRES_PASSWORD=kucharka
POSTGRES_DB=kucharka

# --- Porty na hostiteli ---
# Web (frontend)
FRONTEND_PORT=8080
# Backend API
BACKEND_PORT=3000

# --- Frontend ---
# Základní cesta k API (výchozí /api = proxy přes nginx v kontejneru)
VITE_API_BASE=/api
